# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=sow_generator

# ── JWT / Auth ────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
# Optional; when set, overrides ALGORITHM for JWT sign/verify
JWT_ALGORITHM=
# FSD §3.4 — access ~8h; refresh longer when login form sends remember_me=true
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_EXPIRE_DAYS_SHORT=1
AUTH_PASSWORD_FAILS_BEFORE_LOCKOUT=5
AUTH_TOTP_FAILS_BEFORE_LOCKOUT=3
AUTH_LOCKOUT_MINUTES=15
MAX_CONCURRENT_SESSIONS=3
MFA_RECOVERY_CODE_COUNT=8

# ── TOTP (MFA) ────────────────────────────────────────────────────────────────
TOTP_ISSUER=GlimmoraTeam
# Pending setup (mfa_temp_secret) TTL; TOTP step interval is TOTP_INTERVAL_SECONDS (default 30)
OTP_EXPIRE_SECONDS=300
TOTP_INTERVAL_SECONDS=30

# ── NextAuth compatibility ────────────────────────────────────────────────────
# Must match NEXTAUTH_SECRET in your Next.js .env
NEXTAUTH_SECRET=your-nextauth-secret

# ── OAuth / SSO ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
# Set to False in production and wire a real SMS/email gateway
OTP_DRY_RUN=True

# ── Platform ──────────────────────────────────────────────────────────────────
MIN_BUDGET_INR=500000
MIN_BUDGET_USD=6000
# Comma-separated emails that may call POST /users (create reviewer) without DB role admin
PLATFORM_ADMIN_EMAILS=
# Set True to mount ``/api/v1/reviewer/*``. False = reviewer API on hold (routes not registered).
REVIEWER_API_ENABLED=False
